generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MaterialType {
  cable
  mcb
  switch
  socket
  panel
  conduit
}

enum InstallationType {
  standard
  premium
}

model Material {
  id           Int           @id @default(autoincrement())
  name         String
  type         MaterialType
  unit         String
  pricePerUnit Decimal       @db.Decimal(12,2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@unique([name, type], name: "name_type")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String?
  role             UserRole @default(USER)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  estimations      Estimation[]
}

model Estimation {
  id               Int               @id @default(autoincrement())
  createdAt        DateTime          @default(now())
  houseArea        Int
  lampPoints       Int
  socketPoints     Int
  acCount          Int
  pumpCount        Int
  powerCapacity    Int
  installationType InstallationType
  breakdown        Json
  totalCost        Decimal           @db.Decimal(14,2)
  userId           String?
  user             User?             @relation(fields: [userId], references: [id])
}
