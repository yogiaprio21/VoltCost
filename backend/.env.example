NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
JWT_SECRET=your-super-secret-key
JWT_EXPIRES_IN=7d

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
